APP_NAME=CausalCast AI
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./causalcast.db
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
DATASET_STORAGE_ROOT=../data/raw
DATASET_UPLOAD_DIR=uploads
DATASET_QUARANTINE_DIR=quarantine
DATASET_ARCHIVE_DIR=archived
MAX_UPLOAD_SIZE_MB=25
ALLOWED_DATASET_EXTENSIONS=csv
DATASET_PREVIEW_ROWS=20
DATASET_MAX_COLUMNS=500
DATASET_MAX_ROWS_FOR_PREVIEW_SCAN=10000
DATASET_INGESTION_VERSION=1
DATASET_DELETE_MODE=archive
SCHEMA_INFERENCE_SAMPLE_ROWS=5000
SCHEMA_INFERENCE_PREVIEW_VALUES=10
SCHEMA_INFERENCE_MIN_CONFIDENCE=0.60
SCHEMA_INFERENCE_AUTO_CONFIRM_THRESHOLD=0.92
SCHEMA_INFERENCE_AMBIGUITY_MARGIN=0.10
SCHEMA_INFERENCE_VERSION=1.0
SCHEMA_INFERENCE_MAX_CELL_LENGTH=200
SCHEMA_INFERENCE_MAX_UNIQUE_TRACKING=10000
